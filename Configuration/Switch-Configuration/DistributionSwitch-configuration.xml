<distribution-switches>

  <!-- ========================= -->
  <!-- DIST SWITCH 1 -->
  <!-- ========================= -->
  <switch id="1">

    <identity>
      <hostname>DIST-SW1</hostname>
      <management-ip>172.16.80.11</management-ip>
      <default-gateway>172.16.80.1</default-gateway>
      <management-vlan>80</management-vlan>
    </identity>

    <vlans>
      <vlan id="10"/>
      <vlan id="20"/>
      <vlan id="80"/>
      <vlan id="99"/>
    </vlans>

    <uplink>
      <ports>1-7</ports>
      <mode>trunk</mode>
      <native-vlan>99</native-vlan>
      <allowed-vlans>10,20,80</allowed-vlans>
      <channel-group>1</channel-group>
    </uplink>

  </switch>

  <!-- ========================= -->
  <!-- DIST SWITCH 2 -->
  <!-- ========================= -->
  <switch id="2">

    <identity>
      <hostname>DIST-SW2</hostname>
      <management-ip>172.16.80.12</management-ip>
      <default-gateway>172.16.80.1</default-gateway>
      <management-vlan>80</management-vlan>
    </identity>

    <vlans>
      <vlan id="30"/>
      <vlan id="40"/>
      <vlan id="50"/>
      <vlan id="60"/>
      <vlan id="70"/>
      <vlan id="99"/>
    </vlans>

    <uplink>
      <ports>1-7</ports>
      <mode>trunk</mode>
      <native-vlan>99</native-vlan>
      <allowed-vlans>30,40,50,60,70</allowed-vlans>
      <channel-group>2</channel-group>
    </uplink>

  </switch>

  <!-- ========================= -->
  <!-- DIST SWITCH 3 -->
  <!-- ========================= -->
  <switch id="3">

    <identity>
      <hostname>DIST-SW3</hostname>
      <management-ip>172.16.80.13</management-ip>
      <default-gateway>172.16.80.1</default-gateway>
      <management-vlan>80</management-vlan>
    </identity>

    <vlans>
      <vlan id="90"/>
      <vlan id="99"/>
    </vlans>

    <uplink>
      <ports>1-7</ports>
      <mode>trunk</mode>
      <native-vlan>99</native-vlan>
      <allowed-vlans>90</allowed-vlans>
      <channel-group>3</channel-group>
    </uplink>

  </switch>

  <!-- ========================= -->
  <!-- ACCESS PORT SECURITY -->
  <!-- ========================= -->
  <access-security>
    <portfast>true</portfast>
    <bpdu-guard>true</bpdu-guard>
    <port-security>
      <enabled>true</enabled>
      <max-mac>2</max-mac>
      <violation>shutdown</violation>
    </port-security>
  </access-security>

</distribution-switches>